{
  "manifest_version": 3,
  "name": "CrossList EU",
  "version": "1.0.3",
  "description": "Automatisch crosslisten naar Marktplaats, 2dehands en meer",
  "permissions": ["storage", "tabs", "alarms", "clipboardWrite", "clipboardRead", "scripting"],
  "host_permissions": [
    "https://www.marktplaats.nl/*",
    "https://www.2dehands.be/*",
    "https://link.marktplaats.nl/*",
    "https://www.vinted.com/*",
    "https://www.vinted.nl/*",
    "https://www.vinted.be/*",
    "https://www.vinted.de/*",
    "https://www.vinted.fr/*",
    "https://crosslisteu.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://crosslisteu.com/*", "https://www.crosslisteu.com/*"],
      "js": ["content/webapp_sync.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.marktplaats.nl/plaats/*"],
      "js": ["content/shared.js", "content/marktplaats.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.2dehands.be/plaats/*"],
      "js": ["content/shared.js", "content/tweedehands.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.vinted.com/items/new", "https://www.vinted.com/items/*",
        "https://www.vinted.nl/items/*",
        "https://www.vinted.be/items/*",
        "https://www.vinted.de/items/*",
        "https://www.vinted.fr/items/*"
      ],
      "js": ["content/shared.js", "content/vinted.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.marktplaats.nl/mijn-marktplaats/advertenties/*", "https://www.marktplaats.nl/v/listing/*"],
      "js": ["content/shared.js", "content/marktplaats.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.2dehands.be/mijn-2dehands/advertenties/*", "https://www.2dehands.be/v/listing/*"],
      "js": ["content/shared.js", "content/tweedehands.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CrossList EU"
  }
}
